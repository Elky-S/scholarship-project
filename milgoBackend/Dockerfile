# הגדרת סביבת העבודה: שימוש בגרסה קלה של Node.js
FROM node:18-alpine

# הגדרת תיקיית העבודה בתוך הקונטיינר
WORKDIR /app

# העתקת קבצי ניהול החבילות תחילה (כדי לנצל את מנגנון ה-Cache של דוקר)
COPY package*.json ./

# התקנת הספריות והתלויות
RUN npm install

# העתקת כל שאר קבצי השרת אל תוך הקונטיינר
COPY . .

# חשיפת הפורט שעליו השרת עובד (יש לשנות אם השרת שלך משתמש בפורט אחר, למשל 3000 או 8080)
EXPOSE 5000

# הפקודה שתרוץ כאשר הקונטיינר עולה
CMD ["node", "server.js"]